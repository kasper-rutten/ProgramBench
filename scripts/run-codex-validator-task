set +e
CODEX_BIN="$codex_bin" MODEL="$model" REASONING_EFFORT="$reasoning_effort" WORKSPACE="$workspace" \
  PROMPT="$prompt" FINAL="$final" EVENTS="$events" WALL_CLOCK_SECONDS="$wall_clock_seconds" \
  SAME_COST_MODE="$same_cost_mode" INSTANCE_OUT="$instance_out" INSTANCE_ID="$instance_id" \
  COST_METER_PATH="$repo_root/$run_dir/accounting/$instance_id.cost.json" \
  CHECKPOINT_DIR="$repo_root/$run_dir/checkpoints/$instance_id" \
  SIMULATED_COST_LIMIT="$simulated_cost_limit" \
  SIMULATED_COST_UNIT="$simulated_cost_unit" \
  SIMULATED_COST_RATE_CARD="$simulated_cost_rate_card" \
  SIMULATED_COST_INPUT_PER_MTOK="$simulated_cost_input_per_mtok" \
  SIMULATED_COST_CACHED_INPUT_PER_MTOK="$simulated_cost_cached_input_per_mtok" \
	  SIMULATED_COST_OUTPUT_PER_MTOK="$simulated_cost_output_per_mtok" \
	  SIMULATED_COST_REASONING_PER_MTOK="$simulated_cost_reasoning_per_mtok" \
	  SIMULATED_COST_TURN_WALL_CLOCK_SECONDS="$same_cost_turn_wall_clock_seconds" \
	  SIMULATED_COST_MAX_TURNS="$same_cost_max_turns" \
	  SOLVER_EGRESS_MODE="$solver_egress_mode" \
	  SOLVER_EGRESS_GUARD="$solver_egress_guard" \
	  SOLVER_EGRESS_GUARD_ACTIVE="${PROGRAMBENCH_SOLVER_EGRESS_GUARD_ACTIVE:-}" \
	  CLEANROOM_IMAGE="$cleanroom_image" DOCKER_WRAPPER="$docker_wrapper" \
	  ORACLE_ROOT="$oracle_root" HOST_VALIDATOR_SCRIPT="$oracle_host_root/run-validator-host.sh" \
	  VALIDATOR_TIMEOUT_SECONDS="$validator_timeout_seconds" python3 - <<'PY'
import atexit
import base64
import json
import os
import re
import selectors
import signal
import subprocess
import sys
import tarfile
import threading
import time
from pathlib import Path

workspace = Path(os.environ["WORKSPACE"])
oracle_root = Path(os.environ["ORACLE_ROOT"])
request_dir = oracle_root / "requests"
response_dir = oracle_root / "responses"
stop_oracle = threading.Event()


def write_response(request_id: str, exit_code: int, stdout: bytes, stderr: bytes) -> None:
    payload = {
        "exit_code": exit_code,
        "stdout_b64": base64.b64encode(stdout).decode(),
        "stderr_b64": base64.b64encode(stderr).decode(),
    }
    tmp = response_dir / f".{request_id}.tmp"
    dst = response_dir / f"{request_id}.json"
    tmp.write_text(json.dumps(payload) + "\n")
    tmp.rename(dst)


def handle_request(path: Path) -> None:
    try:
        request = json.loads(path.read_text())
        request_id = request["id"]
        kind = request.get("kind")
        if kind == "reference":
            cmd = [
                os.environ["DOCKER_WRAPPER"],
                "run",
                "--rm",
                "-i",
                "--network",
                "none",
                "--platform",
                "linux/amd64",
                os.environ["CLEANROOM_IMAGE"],
                "/workspace/executable",
                *[str(arg) for arg in request.get("args", [])],
            ]
            proc = subprocess.run(
                cmd,
                input=base64.b64decode(request.get("stdin_b64", "")),
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                timeout=int(os.environ.get("PROGRAMBENCH_REFERENCE_TIMEOUT_SECONDS", "120")),
            )
            write_response(request_id, proc.returncode, proc.stdout, proc.stderr)
        elif kind == "validator":
            cmd = [os.environ["HOST_VALIDATOR_SCRIPT"]]
            proc = subprocess.run(
                cmd,
                cwd=workspace,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                timeout=int(os.environ["VALIDATOR_TIMEOUT_SECONDS"]) + 60,
            )
            write_response(request_id, proc.returncode, proc.stdout, b"")
        else:
            write_response(request_id, 2, b"", f"unknown oracle request kind: {kind}\n".encode())
    except Exception as exc:
        request_id = path.stem
        try:
            request_id = json.loads(path.read_text()).get("id", request_id)
        except Exception:
            pass
        write_response(str(request_id), 1, b"", f"oracle broker error: {exc}\n".encode())
    finally:
        path.unlink(missing_ok=True)


def oracle_loop() -> None:
    while not stop_oracle.is_set():
        for path in sorted(request_dir.glob("*.json")):
            processing = path.with_suffix(".processing")
            try:
                path.rename(processing)
            except FileNotFoundError:
                continue
            handle_request(processing)
        time.sleep(0.05)


oracle_thread = threading.Thread(target=oracle_loop, name="programbench-oracle", daemon=True)
oracle_thread.start()


def stop_oracle_thread() -> None:
    stop_oracle.set()
    oracle_thread.join(timeout=2)


atexit.register(stop_oracle_thread)

def run_codex(cmd: list[str], stdin_path: Path, event_file, timeout: int) -> tuple[int, bool, dict]:
    stdin_file = stdin_path.open("rb")
    proc = subprocess.Popen(
        cmd,
        stdin=stdin_file,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        preexec_fn=os.setsid,
    )
    start = time.monotonic()
    assert proc.stdout is not None
    selector = selectors.DefaultSelector()
    selector.register(proc.stdout, selectors.EVENT_READ)
    timed_out = False
    try:
        while True:
            if time.monotonic() - start > timeout:
                timed_out = True
                os.killpg(proc.pid, signal.SIGTERM)
                try:
                    proc.wait(timeout=10)
                except subprocess.TimeoutExpired:
                    os.killpg(proc.pid, signal.SIGKILL)
                    proc.wait()
                break
            for key, _ in selector.select(timeout=0.2):
                chunk = key.fileobj.readline()
                if chunk:
                    invocation_lines.append(chunk)
                    sys.stdout.buffer.write(chunk)
                    sys.stdout.buffer.flush()
                    event_file.write(chunk)
                    event_file.flush()
                    continue
            if proc.poll() is not None:
                for chunk in proc.stdout.readlines():
                    invocation_lines.append(chunk)
                    sys.stdout.buffer.write(chunk)
                    event_file.write(chunk)
                sys.stdout.buffer.flush()
                event_file.flush()
                break
    finally:
        selector.close()
        if proc.stdout is not None:
            proc.stdout.close()
        stdin_file.close()
    rc = proc.returncode if proc.returncode is not None else proc.wait()
    return (124 if timed_out else rc), timed_out, parse_invocation_events(invocation_lines)


def make_initial_cmd(ephemeral: bool) -> list[str]:
    codex_sandbox = "danger-full-access" if os.environ["SOLVER_EGRESS_MODE"] in {"off", "unguarded"} else "workspace-write"
    cmd = [
        os.environ["CODEX_BIN"],
        "exec",
        "--ignore-user-config",
        "--ignore-rules",
        "-m",
        os.environ["MODEL"],
        "-c",
        f"model_reasoning_effort={os.environ['REASONING_EFFORT']!r}",
        "--cd",
        os.environ["WORKSPACE"],
        "--sandbox",
        codex_sandbox,
        "-c",
        'approval_policy="never"',
        "--json",
        "--color",
        "never",
        "--skip-git-repo-check",
        "--output-last-message",
        os.environ["FINAL"],
    ]
    if ephemeral:
        cmd.insert(cmd.index("--json"), "--ephemeral")
    return cmd


def make_resume_cmd(thread_id: str) -> list[str]:
    return [
        os.environ["CODEX_BIN"],
        "exec",
        "resume",
        "--ignore-user-config",
        "--ignore-rules",
        "-m",
        os.environ["MODEL"],
        "-c",
        f"model_reasoning_effort={os.environ['REASONING_EFFORT']!r}",
        "-c",
        'approval_policy="never"',
        "--json",
        "--skip-git-repo-check",
        "--output-last-message",
        os.environ["FINAL"],
        thread_id,
        "-",
    ]


def parse_invocation_events(lines: list[bytes]) -> dict:
    summary = {
        "thread_id": None,
        "usage": {},
        "validator_result": None,
        "validator_calls": None,
        "validator_passed": None,
        "validator_total": None,
        "solved": False,
    }
    result_re = re.compile(r"VALIDATOR_RESULT:\s*(?P<result>[^\n]+)")
    calls_re = re.compile(r"VALIDATOR_CALLS:\s*(?P<count>\d+)/(?:\d+)")
    passed_re = re.compile(r"PASSED:\s*(?P<passed>\d+)/(?:\s*)?(?P<total>\d+)")
    for raw in lines:
        line = raw.decode(errors="replace")
        if not line.startswith("{"):
            continue
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        if event.get("type") == "thread.started":
            summary["thread_id"] = event.get("thread_id")
        if event.get("type") == "turn.completed" and isinstance(event.get("usage"), dict):
            summary["usage"] = {k: int(v) for k, v in event["usage"].items() if isinstance(v, int)}
        item = event.get("item")
        if not isinstance(item, dict) or item.get("type") != "command_execution":
            continue
        command = str(item.get("command") or "")
        output = str(item.get("aggregated_output") or "")
        if "run-validator.sh" not in command or "VALIDATOR_RESULT:" not in output:
            continue
        result_match = result_re.search(output)
        calls_match = calls_re.search(output)
        passed_match = passed_re.search(output)
        if result_match:
            result = result_match.group("result").strip()
            summary["validator_result"] = result
            summary["solved"] = result == "SOLVED"
        if calls_match:
            summary["validator_calls"] = int(calls_match.group("count"))
        if passed_match:
            summary["validator_passed"] = int(passed_match.group("passed"))
            summary["validator_total"] = int(passed_match.group("total"))
    return summary


def usage_cost(usage: dict, rates: dict[str, float]) -> float:
    input_tokens = int(usage.get("input_tokens", 0))
    cached_tokens = int(usage.get("cached_input_tokens", 0))
    uncached_tokens = max(0, input_tokens - cached_tokens)
    output_tokens = int(usage.get("output_tokens", 0))
    reasoning_tokens = int(usage.get("reasoning_output_tokens", 0))
    return (
        uncached_tokens * rates["input"]
        + cached_tokens * rates["cached_input"]
        + output_tokens * rates["output"]
        + reasoning_tokens * rates["reasoning"]
    ) / 1_000_000


def make_submission_tar(dst: Path) -> None:
    src = Path(os.environ["WORKSPACE"])
    exclude_names = {
        "query-reference.sh",
        "docker-colima-local",
        "run-validator.sh",
        "executable",
        ".validator-call-count",
        ".programbench-oracle-client.py",
    }
    exclude_roots = {
        "reference",
        ".git",
        "__pycache__",
        ".pytest_cache",
        ".mypy_cache",
        ".validator-artifacts",
        ".programbench-oracle",
        ".pbtmp",
    }
    dst.parent.mkdir(parents=True, exist_ok=True)
    with tarfile.open(dst, "w:gz") as tf:
        for path in sorted(src.rglob("*")):
            rel = path.relative_to(src)
            if rel.parts[0] in exclude_roots or rel.name in exclude_names:
                continue
            info = tf.gettarinfo(str(path), arcname=str(rel))
            info.uid = info.gid = 0
            info.uname = info.gname = "root"
            if path.is_file():
                with path.open("rb") as f:
                    tf.addfile(info, f)
            else:
                tf.addfile(info)


def write_resume_prompt(path: Path, turn: int) -> None:
    path.write_text(
        "Continue the ProgramBench task in the same workspace.\n"
        f"Controller iteration: {turn}.\n"
        "Make one focused improvement, run ./run-validator.sh at most once, then stop and summarize the validator result.\n"
        "If ./run-validator.sh reports SOLVED, stop immediately after summarizing it.\n"
    )


events = Path(os.environ["EVENTS"])
events.parent.mkdir(parents=True, exist_ok=True)
invocation_lines: list[bytes] = []

# Normal mode: preserve the original single ephemeral Codex turn.
if os.environ["SAME_COST_MODE"] != "1":
    with events.open("wb") as event_file:
        rc, timed_out, _ = run_codex(
            make_initial_cmd(ephemeral=True),
            Path(os.environ["PROMPT"]),
            event_file,
            int(os.environ["WALL_CLOCK_SECONDS"]),
        )
    sys.exit(rc)

cost_limit = float(os.environ["SIMULATED_COST_LIMIT"])
cost_unit = os.environ["SIMULATED_COST_UNIT"]
rate_card = os.environ["SIMULATED_COST_RATE_CARD"]
rates = {
    "input": float(os.environ["SIMULATED_COST_INPUT_PER_MTOK"]),
    "cached_input": float(os.environ["SIMULATED_COST_CACHED_INPUT_PER_MTOK"]),
    "output": float(os.environ["SIMULATED_COST_OUTPUT_PER_MTOK"]),
    "reasoning": float(os.environ["SIMULATED_COST_REASONING_PER_MTOK"]),
}
turn_timeout = int(os.environ["SIMULATED_COST_TURN_WALL_CLOCK_SECONDS"])
max_turns = int(os.environ["SIMULATED_COST_MAX_TURNS"])
overall_timeout = int(os.environ["WALL_CLOCK_SECONDS"])
checkpoint_dir = Path(os.environ["CHECKPOINT_DIR"])
checkpoint_dir.mkdir(parents=True, exist_ok=True)
cost_path = Path(os.environ["COST_METER_PATH"])
resume_prompt = checkpoint_dir / "resume-prompt.txt"
final_submission = Path(os.environ["INSTANCE_OUT"]) / "submission.tar.gz"

trace = []
thread_id = None
cumulative_cost = 0.0
selected_checkpoint: Path | None = None
selected_cost: float | None = None
selected_turn: int | None = None
selected_validator_calls = 0
last_checkpoint: Path | None = None
last_rc = 0
started = time.monotonic()

with events.open("wb") as event_file:
    for turn in range(1, max_turns + 1):
        remaining_wall = overall_timeout - int(time.monotonic() - started)
        if remaining_wall <= 0:
            last_rc = 124
            break
        invocation_lines = []
        if turn == 1:
            stdin_path = Path(os.environ["PROMPT"])
            cmd = make_initial_cmd(ephemeral=False)
        else:
            assert thread_id is not None
            write_resume_prompt(resume_prompt, turn)
            stdin_path = resume_prompt
            cmd = make_resume_cmd(thread_id)

        rc, timed_out, summary = run_codex(cmd, stdin_path, event_file, min(turn_timeout, remaining_wall))
        last_rc = rc
        if summary.get("thread_id"):
            thread_id = summary["thread_id"]
        usage = summary.get("usage") or {}
        turn_cost = usage_cost(usage, rates)
        cumulative_cost += turn_cost
        checkpoint = checkpoint_dir / f"turn-{turn:03d}-submission.tar.gz"
        make_submission_tar(checkpoint)
        last_checkpoint = checkpoint
        within_budget = cumulative_cost <= cost_limit
        validator_calls = summary.get("validator_calls")
        if isinstance(validator_calls, int):
            selected_validator_calls = max(selected_validator_calls, validator_calls)
        if within_budget:
            selected_checkpoint = checkpoint
            selected_cost = cumulative_cost
            selected_turn = turn
        trace.append(
            {
                "turn": turn,
                "exit_code": rc,
                "timed_out": timed_out,
                "usage": usage,
                "turn_simulated_cost_usd": turn_cost,
                "cumulative_simulated_cost_usd": cumulative_cost,
                "within_budget": within_budget,
                "checkpoint": str(checkpoint),
                "validator_result": summary.get("validator_result"),
                "validator_calls": validator_calls,
                "validator_passed": summary.get("validator_passed"),
                "validator_total": summary.get("validator_total"),
            }
        )
        if timed_out or rc not in (0, 124):
            break
        if summary.get("solved"):
            break
        if cumulative_cost > cost_limit:
            break
        if thread_id is None:
            break

if selected_checkpoint is None:
    selected_checkpoint = last_checkpoint
    selected_cost = cumulative_cost if last_checkpoint is not None else None
    selected_turn = trace[-1]["turn"] if trace else None

if selected_checkpoint is not None:
    final_submission.parent.mkdir(parents=True, exist_ok=True)
    final_submission.write_bytes(selected_checkpoint.read_bytes())

cost_payload = {
    "same_cost_mode": True,
    "simulated_cost_limit": cost_limit,
    "simulated_cost_unit": cost_unit,
    "simulated_cost_rate_card": rate_card,
    "simulated_cost_rates_per_mtok": rates,
    "simulated_cost": cumulative_cost,
    "simulated_cost_selected": selected_cost,
    "simulated_cost_exceeded": cumulative_cost > cost_limit,
    "simulated_cost_turn_wall_clock_seconds": turn_timeout,
    "simulated_cost_max_turns": max_turns,
    "checkpoint_count": len(trace),
    "selected_checkpoint": str(selected_checkpoint) if selected_checkpoint is not None else None,
    "selected_turn": selected_turn,
    "selected_validator_call_count": selected_validator_calls,
    "trace": trace,
}
if cost_unit == "api_usd":
    cost_payload["simulated_cost_limit_usd"] = cost_limit
    cost_payload["simulated_cost_usd"] = cumulative_cost
    cost_payload["simulated_cost_selected_usd"] = selected_cost
cost_path.parent.mkdir(parents=True, exist_ok=True)
cost_path.write_text(json.dumps(cost_payload, indent=2, sort_keys=True) + "\n")
sys.exit(last_rc)
PY
codex_status="$?"
