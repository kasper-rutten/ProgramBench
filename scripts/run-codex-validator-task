  EVAL_BRANCH_WORKERS="$eval_branch_workers" EVAL_DOCKER_CPUS="$eval_docker_cpus" python3 - <<'PY'
import json
import os
from pathlib import Path

started = float(os.environ["STARTED_S"])
ended = float(os.environ["ENDED_S"])
payload = {
    "instance_id": os.environ["INSTANCE_ID"],
    "model": os.environ["MODEL"],
    "reasoning_effort": os.environ["REASONING_EFFORT"],
    "harness_mode": os.environ["HARNESS_MODE"],
    "started_at": os.environ["STARTED_AT"],
    "ended_at": os.environ["ENDED_AT"],
    "wall_time_seconds": max(0.0, ended - started),
    "wall_clock_limit_seconds": int(os.environ["WALL_CLOCK_LIMIT_SECONDS"]),
    "validator_call_limit": int(os.environ["VALIDATOR_CALL_LIMIT"]),
    "validator_call_count": int(os.environ["VALIDATOR_CALL_COUNT"]),
    "validator_timeout_seconds": int(os.environ["VALIDATOR_TIMEOUT_SECONDS"]),
    "validator_failure_limit": int(os.environ["VALIDATOR_FAILURE_LIMIT"]),
    "validator_failure_chars": int(os.environ["VALIDATOR_FAILURE_CHARS"]),
    "eval_workers": int(os.environ["EVAL_WORKERS"]),
    "eval_branch_workers": int(os.environ["EVAL_BRANCH_WORKERS"]),
    "eval_docker_cpus": int(os.environ["EVAL_DOCKER_CPUS"]),
    "codex_exit_code": int(os.environ["CODEX_STATUS"]),
    "solver_network": os.environ["SOLVER_EGRESS_MODE"],
    "solver_egress_guard": os.environ["SOLVER_EGRESS_GUARD"],
    "solver_egress_guard_active": (
        os.environ["SOLVER_EGRESS_GUARD_ACTIVE"] == "1"
        or os.environ["SOLVER_EGRESS_GUARD"] == "codex-workspace-write-filesystem-oracle"
    ),
}
cost_path = Path(os.environ["COST_METER_PATH"])
if os.environ["SAME_COST_MODE"] == "1" and cost_path.exists():
    cost_payload = json.loads(cost_path.read_text())
    payload.update(
        {
            "same_cost_mode": True,
            "simulated_cost_limit": cost_payload.get("simulated_cost_limit"),
            "simulated_cost_unit": cost_payload.get("simulated_cost_unit"),
            "simulated_cost_rate_card": cost_payload.get("simulated_cost_rate_card"),
            "simulated_cost_rates_per_mtok": cost_payload.get("simulated_cost_rates_per_mtok"),
            "simulated_cost": cost_payload.get("simulated_cost"),
            "simulated_cost_selected": cost_payload.get("simulated_cost_selected"),
            "simulated_cost_exceeded": cost_payload.get("simulated_cost_exceeded"),
            "simulated_cost_turn_wall_clock_seconds": cost_payload.get("simulated_cost_turn_wall_clock_seconds"),
            "simulated_cost_max_turns": cost_payload.get("simulated_cost_max_turns"),
            "checkpoint_count": cost_payload.get("checkpoint_count"),
            "selected_checkpoint": cost_payload.get("selected_checkpoint"),
            "selected_turn": cost_payload.get("selected_turn"),
            "selected_validator_call_count": cost_payload.get("selected_validator_call_count"),
            "cost_meter_path": str(cost_path),
        }
    )
    if cost_payload.get("simulated_cost_unit") == "api_usd":
        payload["simulated_cost_limit_usd"] = cost_payload.get("simulated_cost_limit_usd")
        payload["simulated_cost_usd"] = cost_payload.get("simulated_cost_usd")
        payload["simulated_cost_selected_usd"] = cost_payload.get("simulated_cost_selected_usd")
path = Path(os.environ["ACCOUNTING_PATH"])
path.parent.mkdir(parents=True, exist_ok=True)
path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n")
PY

if [[ "$codex_status" -ne 0 && "$codex_status" -ne 124 ]]; then
  exit "$codex_status"
fi

if [[ "$same_cost_mode" == "1" && -f "$instance_out/submission.tar.gz" ]]; then
  echo "$instance_out/submission.tar.gz"
  exit 0
fi

SUBMISSION_SRC="$workspace" SUBMISSION_TAR="$instance_out/submission.tar.gz" python3 - <<'PY'
import os
import tarfile
from pathlib import Path

src = Path(os.environ["SUBMISSION_SRC"])
dst = Path(os.environ["SUBMISSION_TAR"])
exclude_names = {
    "query-reference.sh",
    "docker-colima-local",
    "run-validator.sh",
    "executable",
    ".validator-call-count",
    ".programbench-oracle-client.py",
}
exclude_roots = {
    "reference",
    ".git",
    "__pycache__",
    ".pytest_cache",
    ".mypy_cache",
    ".validator-artifacts",
    ".programbench-oracle",
    ".pbtmp",
}
dst.parent.mkdir(parents=True, exist_ok=True)
with tarfile.open(dst, "w:gz") as tf:
    for path in sorted(src.rglob("*")):
        rel = path.relative_to(src)
        if rel.parts[0] in exclude_roots or rel.name in exclude_names:
            continue
        info = tf.gettarinfo(str(path), arcname=str(rel))
        info.uid = info.gid = 0
        info.uname = info.gname = "root"
        if path.is_file():
            with path.open("rb") as f:
                tf.addfile(info, f)
        else:
            tf.addfile(info)
print(dst)
PY
